{
  "name": "markscribe",
  "version": "0.3.0",
  "description": "Convention-aware markdown MCP server",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "markscribe": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "markdown",
    "mcp",
    "conventions",
    "schema",
    "obsidian",
    "foam",
    "digital-garden",
    "documentation"
  ],
  "author": "Owen Sterling",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Erodenn/markscribe.git"
  },
  "homepage": "https://github.com/Erodenn/markscribe#readme",
  "bugs": {
    "url": "https://github.com/Erodenn/markscribe/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
